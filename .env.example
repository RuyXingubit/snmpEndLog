# ============================================
# snmpEndLog — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# ============================================

# PostgreSQL / TimescaleDB
POSTGRES_DB=snmpendlog
POSTGRES_USER=snmpendlog
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# Web Server
WEB_PORT=8080
JWT_SECRET=CHANGE_ME_USE_A_RANDOM_STRING_AT_LEAST_32_CHARS

# Initial Admin User (created on first startup)
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# SNMP Defaults
SNMP_DEFAULT_INTERVAL=300

# Syslog Receiver
LOG_UDP_PORT=514
LOG_TCP_PORT=514
